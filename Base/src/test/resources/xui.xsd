						<xsd:attribute name="namespace" type="xsd:string" use="optional"/>
						<xsd:attribute name="global" type="xsd:boolean" use="optional" default="false"/>
						<xsd:attribute name="enabled" type="xsd:boolean" use="optional"/>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="settings" minOccurs="0">
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="types" minOccurs="0">
								<xsd:complexType>
									<xsd:sequence>
										<xsd:element name="list" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="initialization">
														<xsd:complexType>
															<xsd:choice>
																<xsd:element name="none"/>
																<xsd:element name="minOcc"/>
																<xsd:element name="maxOcc"/>
																<xsd:element name="one"/>
																<xsd:element name="custom" type="xsd:int"/>
															</xsd:choice>
														</xsd:complexType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="choice" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="selectFirst" type="xsd:boolean"/>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
									</xsd:sequence>
								</xsd:complexType>
							</xsd:element>
							<xsd:element name="serialization" minOccurs="0">
								<xsd:complexType>
									<xsd:sequence>
										<xsd:element name="serializeDefaultValue" type="xsd:boolean" minOccurs="0"/>
										<xsd:element name="serializeNamespace" type="xsd:boolean" default="false" minOccurs="0"/>
										<xsd:element name="serializeNamespacePrefix" type="xsd:boolean" default="true" minOccurs="0"/>
										<xsd:element name="serializeUnnamed" type="xsd:boolean" default="true" minOccurs="0"/>
									</xsd:sequence>
								</xsd:complexType>
							</xsd:element>
							<xsd:element name="rendering" minOccurs="0">
								<xsd:complexType>
									<xsd:sequence>
										<xsd:element name="time" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="visualizer"/>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="date" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="visualizer">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string">
																<xsd:enumeration value="org.model.ui.html.render.actas.DateRenderer"/>
																<xsd:enumeration value="org.model.ui.html.render.actas.DateTimeRenderer"/>
															</xsd:restriction>
														</xsd:simpleType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="dateTime" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="visualizer"/>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="boolean" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="visualizer">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string">
																<xsd:enumeration value="org.model.ui.html.render.BooleanRenderer"/>
																<xsd:enumeration value="org.model.ui.html.render.BooleanSwitchRenderer"/>
																<xsd:enumeration value="org.model.ui.html.render.SerializeSwitchRenderer"/>
															</xsd:restriction>
														</xsd:simpleType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="duration" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="visualizer"/>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="label" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="position" default="LEFT" minOccurs="0">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string">
																<xsd:enumeration value="LEFT"/>
																<xsd:enumeration value="RIGHT"/>
																<xsd:enumeration value="TOP"/>
																<xsd:enumeration value="BOTTOM"/>
																<xsd:enumeration value="INLINE"/>
																<xsd:enumeration value="BORDER"/>
																<xsd:enumeration value="NOT_DEFINED"/>
															</xsd:restriction>
														</xsd:simpleType>
													</xsd:element>
													<xsd:element name="choiceUseLabel" type="xsd:boolean" minOccurs="0"/>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="caption" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="type" minOccurs="0">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string">
																<xsd:enumeration value="border"/>
																<xsd:enumeration value="header"/>
																<xsd:enumeration value="accordion"/>
															</xsd:restriction>
														</xsd:simpleType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="help" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="position" default="LEFT" minOccurs="0">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string">
																<xsd:enumeration value="LEFT"/>
																<xsd:enumeration value="TOP"/>
																<xsd:enumeration value="BOTTOM"/>
																<xsd:enumeration value="NOT_DEFINED"/>
															</xsd:restriction>
														</xsd:simpleType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
									</xsd:sequence>
								</xsd:complexType>
							</xsd:element>
							<xsd:element name="resources" minOccurs="0">
								<xsd:complexType>
									<xsd:sequence>
										<xsd:element name="rest" type="httpResourceType" minOccurs="0" maxOccurs="unbounded"/>
										<xsd:element name="soap" minOccurs="0" maxOccurs="unbounded"/>
										<xsd:element ref="codes" minOccurs="0"/>
										<xsd:element name="manual" minOccurs="0">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="jsonConfig" minOccurs="0" maxOccurs="unbounded">
														<xsd:complexType>
															<xsd:sequence>
																<xsd:element ref="resourceID"/>
																<xsd:element name="config" type="xsd:string"/>
															</xsd:sequence>
														</xsd:complexType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
									</xsd:sequence>
								</xsd:complexType>
							</xsd:element>
							<xsd:element name="translations" minOccurs="0" maxOccurs="unbounded">
								<xsd:complexType>
									<xsd:sequence>
										<xsd:element name="nls" minOccurs="0" maxOccurs="unbounded">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="path" type="xsd:string"/>
													<xsd:element name="context" minOccurs="0">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string">
																<xsd:enumeration value="label"/>
																<xsd:enumeration value="error"/>
																<xsd:enumeration value="navbar"/>
																<xsd:enumeration value="treeEntry"/>
																<xsd:enumeration value="primitive"/>
																<xsd:enumeration value="paging"/>
																<xsd:enumeration value="caption"/>
																<xsd:enumeration value="help"/>
																<xsd:enumeration value="watermark"/>
																<xsd:enumeration value="message"/>
																<xsd:enumeration value="tooltip"/>
																<xsd:enumeration value="custom"/>
																<xsd:enumeration value="textResource"/>
																<xsd:enumeration value="formula"/>
																<xsd:enumeration value="lineInfo"/>
															</xsd:restriction>
														</xsd:simpleType>
													</xsd:element>
													<xsd:element name="subcontext" minOccurs="0">
														<xsd:simpleType>
															<xsd:restriction base="xsd:string"/>
														</xsd:simpleType>
													</xsd:element>
													<xsd:element name="isFormula" type="xsd:boolean" minOccurs="0"/>
													<xsd:element name="isHTML" type="xsd:boolean" minOccurs="0"/>
													<xsd:element name="value" type="xsd:string"/>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
										<xsd:element name="component" minOccurs="0" maxOccurs="unbounded">
											<xsd:complexType>
												<xsd:sequence>
													<xsd:element name="path" type="xsd:string"/>
													<xsd:element name="nls" minOccurs="0" maxOccurs="unbounded">
														<xsd:complexType>
															<xsd:sequence>
																<xsd:element name="context" minOccurs="0">
																	<xsd:simpleType>
																		<xsd:restriction base="xsd:string">
																			<xsd:enumeration value="label"/>
																			<xsd:enumeration value="error"/>
																			<xsd:enumeration value="navbar"/>
																			<xsd:enumeration value="treeEntry"/>
																			<xsd:enumeration value="primitive"/>
																			<xsd:enumeration value="paging"/>
																			<xsd:enumeration value="caption"/>
																			<xsd:enumeration value="help"/>
																			<xsd:enumeration value="watermark"/>
																			<xsd:enumeration value="message"/>
																			<xsd:enumeration value="tooltip"/>
																			<xsd:enumeration value="custom"/>
																			<xsd:enumeration value="textResource"/>
																			<xsd:enumeration value="formula"/>
																			<xsd:enumeration value="lineInfo"/>
																		</xsd:restriction>
																	</xsd:simpleType>
																</xsd:element>
																<xsd:element name="subcontext" minOccurs="0">
																	<xsd:simpleType>
																		<xsd:restriction base="xsd:string"/>
																	</xsd:simpleType>
																</xsd:element>
																<xsd:element name="isFormula" type="xsd:boolean" minOccurs="0"/>
																<xsd:element name="isHTML" type="xsd:boolean" minOccurs="0"/>
																<xsd:element name="value" type="xsd:string"/>
															</xsd:sequence>
														</xsd:complexType>
													</xsd:element>
												</xsd:sequence>
											</xsd:complexType>
										</xsd:element>
									</xsd:sequence>
									<xsd:attribute name="language" type="xsd:string"/>
								</xsd:complexType>
							</xsd:element>
							<xsd:element name="constants" minOccurs="0" maxOccurs="unbounded">
								<xsd:complexType>
									<xsd:sequence>
										<xsd:element name="key">
											<xsd:simpleType>
												<xsd:restriction base="xsd:string">
													<xsd:enumeration value="CLASS_NODE_LABELED_WIDTH_VALUE_HOLDER"/>
													<xsd:enumeration value="CLASS_NODE_LABEL_LEFT"/>
												</xsd:restriction>
											</xsd:simpleType>
										</xsd:element>
										<xsd:element name="value" type="xsd:string"/>
									</xsd:sequence>
								</xsd:complexType>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="fakeNodes" minOccurs="0" maxOccurs="unbounded">
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="path">
								<xsd:simpleType>
									<xsd:restriction base="xsd:string"/>
								</xsd:simpleType>
							</xsd:element>
							<xsd:element name="type">
								<xsd:simpleType>
									<xsd:restriction base="xsd:string">
										<xsd:enumeration value="simple"/>
										<xsd:enumeration value="complex"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="globalRules">
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="rule" minOccurs="0" maxOccurs="unbounded">
								<xsd:complexType>
									<xsd:complexContent>
										<xsd:extension base="ruleType">
											<xsd:sequence>
												<xsd:element name="basePath" type="xPathType"/>
											</xsd:sequence>
										</xsd:extension>
									</xsd:complexContent>
								</xsd:complexType>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
			</xsd:sequence>
		</xsd:complexType>
	</xsd:element>
	<xsd:complexType name="formulaExpressionType">
		<xsd:sequence>
			<xsd:element name="expression" type="xsd:string"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ActionType">
		<xsd:sequence>
			<xsd:element name="id" type="xsd:ID" minOccurs="0"/>
			<xsd:element ref="xPath" minOccurs="0"/>
			<xsd:element name="enabled" type="xsd:boolean" default="true" minOccurs="0"/>
			<xsd:element name="useActionTargetAsBase" type="xsd:boolean" default="true" minOccurs="0">
				<xsd:annotation>
					<xsd:appinfo source="http://www.model.org/xui/Annotation">
						<pi name="supported" value="no"/>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="eventSourceIsTarget" type="xsd:boolean" default="false" minOccurs="0">
				<xsd:annotation>
					<xsd:appinfo source="http://www.model.org/xui/Annotation">
						<pi name="supported" value="no"/>
					</xsd:appinfo>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="modelChange" type="xsd:boolean" minOccurs="0"/>
			<xsd:element name="formulaExpression" type="formulaExpressionType"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="captionIndentType">
		<xsd:annotation>
			<xsd:documentation>Defines the caption indent of a component.</xsd:documentation>
		</xsd:annotation>
		<xsd:attribute name="applyCaptionIndentOn" use="optional" default="label">
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="label"/>
					<xsd:enumeration value="component"/>
					<xsd:enumeration value="both"/>
				</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="nestedIndent" type="xsd:float" use="optional"/>
	</xsd:complexType>
	<xsd:element name="visibility">
		<xsd:annotation>
			<xsd:documentation>Defines the visibility.</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:choice minOccurs="0">
				<xsd:element name="always">
					<xsd:annotation>
						<xsd:documentation>Is always visible.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="never">
					<xsd:annotation>
						<xsd:documentation>Is never visible.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
		</xsd:complexType>
	</xsd:element>
	<xsd:element name="applyOnDescendants">
		<xsd:annotation>
			<xsd:documentation>Defines the type of dependency for the descendant nodes.</xsd:documentation>
			<xsd:appinfo source="http://www.model.org/xui/Annotation">
				<pi name="supported" value="no"/>
			</xsd:appinfo>
		</xsd:annotation>
		<xsd:complexType/>
	</xsd:element>
	<xsd:complexType name="nlsType">
		<xsd:sequence>
			<xsd:element name="text">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="isFormula" type="xsd:boolean" use="optional"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="description" type="xsd:string" minOccurs="0"/>
			<xsd:element name="tooltip" type="xsd:string" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:attributeGroup name="enumerationType">
		<xsd:annotation>
			<xsd:documentation>Defines the type and the orientation of any enumeration.</xsd:documentation>
		</xsd:annotation>
		<xsd:attribute name="type" use="optional">
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="comboBox"/>
					<xsd:enumeration value="advancedComboBox"/>
					<xsd:enumeration value="comboBoxSearch"/>
					<xsd:enumeration value="radioButton"/>
					<xsd:enumeration value="checkBox"/>
					<xsd:enumeration value="list"/>
					<xsd:enumeration value="listMultiselect"/>
					<xsd:enumeration value="listMultiselectTextBox"/>
				</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="orientation" use="optional">
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="horizontal"/>
					<xsd:enumeration value="vertical"/>
				</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
	</xsd:attributeGroup>
	<xsd:simpleType name="paramType">
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="Boolean"/>
			<xsd:enumeration value="String"/>
			<xsd:enumeration value="String[]"/>
			<xsd:enumeration value="Integer"/>
			<xsd:enumeration value="boolean"/>
			<xsd:enumeration value="int"/>
			<xsd:enumeration value="Color"/>
			<xsd:enumeration value="Visualizer"/>
			<xsd:enumeration value="int[]"/>
			<xsd:enumeration value="Type"/>
			<xsd:enumeration value="URL"/>
			<xsd:enumeration value="SimpleType"/>
			<xsd:enumeration value="org.json.JSONObject"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:element name="param">
		<xsd:annotation>
			<xsd:documentation>Defines a method paramter as an alias(name), type and a value.</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:simpleContent>
				<xsd:extension base="xsd:string">
					<xsd:attribute name="name" type="xsd:string" use="optional"/>
					<xsd:attribute name="type" type="paramType" use="required"/>
					<xsd:attribute name="value" type="xsd:string" use="optional"/>
				</xsd:extension>
			</xsd:simpleContent>
		</xsd:complexType>
	</xsd:element>
	<xsd:element name="resourceID" type="xsd:string"/>
	<xsd:complexType name="httpResourceType">
		<xsd:sequence>
			<xsd:element ref="resourceID"/>
			<xsd:element name="url" type="xsd:anyURI"/>
			<xsd:element name="method" default="post">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="get"/>
						<xsd:enumeration value="post"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="header" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="key"/>
						<xsd:element name="value" minOccurs="0"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="body">
				<xsd:complexType>
					<xsd:choice minOccurs="0">
						<xsd:element name="formdata">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="key"/>
									<xsd:element name="value" minOccurs="0"/>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="raw" type="xsd:string"/>
						<xsd:element name="binary" type="xsd:base64Binary"/>
					</xsd:choice>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="authorization">
				<xsd:complexType>
					<xsd:choice>
						<xsd:element name="none" type="xsd:string"/>
						<xsd:element name="basicauth" type="xsd:string"/>
						<xsd:element name="oauth2" type="xsd:string"/>
						<xsd:element name="bearer" type="xsd:string"/>
					</xsd:choice>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:element name="customComponentElement" type="xsd:string">
		<xsd:annotation>
			<xsd:documentation>a custom text element inserted after element</xsd:documentation>
		</xsd:annotation>
	</xsd:element>
	<xsd:element name="codes" type="codesType">
		<xsd:annotation>
			<xsd:documentation>Comment describing your root element</xsd:documentation>
		</xsd:annotation>
	</xsd:element>
	<xsd:complexType name="entryType">
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="help" type="xsd:string" use="optional"/>
				<xsd:attribute name="param" type="xsd:string" use="optional"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:complexType name="codeSetType">
		<xsd:sequence>
			<xsd:element name="alias" type="xsd:string" minOccurs="0" maxOccurs="unbounded"/>
			<xsd:element name="label" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="de" type="xsd:string"/>
						<xsd:element name="fr" type="xsd:string" minOccurs="0"/>
						<xsd:element name="it" type="xsd:string" minOccurs="0"/>
						<xsd:element name="en" minOccurs="0"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="code" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="values">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="all" type="entryType" minOccurs="0"/>
									<xsd:element name="de" type="entryType" minOccurs="0"/>
									<xsd:element name="fr" type="entryType" minOccurs="0"/>
									<xsd:element name="it" type="entryType" minOccurs="0"/>
									<xsd:element name="en" type="entryType" minOccurs="0"/>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="codeSetRef" type="codeSetRefType" minOccurs="0"/>
					</xsd:sequence>
					<xsd:attribute name="id" type="xsd:string" use="required"/>
					<xsd:attribute name="status" use="optional" default="valid">
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:enumeration value="valid"/>
								<xsd:enumeration value="invalid"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:attribute>
					<xsd:attribute name="param" type="xsd:string" use="optional"/>
					<xsd:attribute name="weight" type="xsd:string" use="optional"/>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="name" type="xsd:string" use="required"/>
		<xsd:attribute name="isHierarchy" type="xsd:boolean" default="false"/>
		<xsd:attribute name="owner" type="xsd:string" use="optional"/>
	</xsd:complexType>
	<xsd:complexType name="codeSetRefType">
		<xsd:complexContent>
			<xsd:extension base="codeSetType"/>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:complexType name="codesType">
		<xsd:sequence>
			<xsd:element name="codeSet" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="codeSetType"/>
					</xsd:complexContent>
				</xsd:complexType>
